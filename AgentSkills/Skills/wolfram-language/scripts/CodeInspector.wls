#!/usr/bin/env wolframscript

(* Generated by BuildAgentSkills.wls - do not edit manually *)

(* :!CodeAnalysis::BeginBlock:: *)
(* :!CodeAnalysis::Disable::SuspiciousSessionSymbol:: *)

(* ::Section:: *)
(*Argument Parsing*)

(* Usage and help text *)
$usage = "wolframscript -script CodeInspector.wls [--code value] [--file value] [--tagExclusions value] [--severityExclusions value] [--confidenceLevel value] [--limit value]";

$helpText = StringJoin[
    "Usage: ", $usage, "\n\n",
    "Inspects Wolfram Language code using the CodeInspector package and returns a formatted report of issues found. The tool supports inspecting code strings, individual files, or entire directories of Wolfram Language source files.\n\n",
    "Arguments:\n",
    "  --code: Wolfram Language code string to inspect.\n",
    "  --file: File or directory path to inspect. For directories, recursively inspects all .wl, .m, and .wls files.\n",
    "  --tagExclusions: Comma-separated list of tags to exclude (e.g., \"UnusedVariable,SuspiciousSessionSymbol\").\n",
    "  --severityExclusions: Comma-separated list of severities to exclude. Default: \"Formatting,Remark,Scoping\". Available: Fatal, Error, Warning, Scoping, Remark, Formatting.\n",
    "  --confidenceLevel: Minimum confidence level (0.0 to 1.0). Default: 0.75. Issues below this confidence are excluded.\n",
    "  --limit: Maximum number of issues to display. Default: 100.\n"
];

(* Check for --help flag *)
If[ MemberQ[ $ScriptCommandLine, "--help" | "-h" ],
    WriteString[ "stdout", $helpText ];
    Exit[ 0 ]
];

(* Parse command-line arguments *)
Module[ { rawArgs, positional, flags, i, key, value },

    rawArgs = Drop[ $ScriptCommandLine, 1 ];
    positional = {};
    flags = <| |>;
    i = 1;

    While[ i <= Length @ rawArgs,
        If[ StringStartsQ[ rawArgs[[ i ]], "--" ],
            key = StringDrop[ rawArgs[[ i ]], 2 ];
            If[ i + 1 <= Length @ rawArgs,
                value = rawArgs[[ i + 1 ]];
                flags[ key ] = value;
                i += 2,
                (* --flag with no value *)
                WriteString[ "stderr", "[Error] Flag --" <> key <> " requires a value.\n" ];
                Exit[ 1 ]
            ],
            AppendTo[ positional, rawArgs[[ i ]] ];
            i += 1
        ]
    ];

    $parsedArgs = <| |>;
    If[ KeyExistsQ[ flags, "code" ], $parsedArgs[ "code" ] = flags[ "code" ] ];
    If[ KeyExistsQ[ flags, "file" ], $parsedArgs[ "file" ] = flags[ "file" ] ];
    If[ KeyExistsQ[ flags, "tagExclusions" ], $parsedArgs[ "tagExclusions" ] = flags[ "tagExclusions" ] ];
    If[ KeyExistsQ[ flags, "severityExclusions" ], $parsedArgs[ "severityExclusions" ] = flags[ "severityExclusions" ] ];
    If[ KeyExistsQ[ flags, "confidenceLevel" ], $parsedArgs[ "confidenceLevel" ] = flags[ "confidenceLevel" ] ];
    If[ KeyExistsQ[ flags, "limit" ], $parsedArgs[ "limit" ] = flags[ "limit" ] ];
];

(* ::Section:: *)
(*Tool Invocation*)

Quiet[
    PacletInstall[ "Wolfram/MCPServer" ],
    PacletInstall::samevers
];
Get[ "Wolfram`MCPServer`" ];

tool = $DefaultMCPTools[ "CodeInspector" ];

If[ ! MatchQ[ tool, _LLMTool ],
    WriteString[ "stderr", "[Error] Failed to load tool: CodeInspector\n" ];
    Exit[ 1 ]
];

result = Quiet[
    tool[ $parsedArgs ],
    { General::messages }
];

(* Handle image content: replace with text placeholder *)
result = StringReplace[
    Replace[ result, Except[ _String ] :> ToString[ result, InputForm ] ],
    RegularExpression[ "!\\[([^]]*)\\]\\(data:image[^)]+\\)" ] -> "[Image: $1]"
];

WriteString[ "stdout", result ];

If[ FailureQ @ result, Exit[ 1 ], Exit[ 0 ] ];

(* :!CodeAnalysis::EndBlock:: *)