#!/usr/bin/env wolframscript

(* Generated by BuildAgentSkills.wls - do not edit manually *)

(* :!CodeAnalysis::BeginBlock:: *)
(* :!CodeAnalysis::Disable::SuspiciousSessionSymbol:: *)

(* ::Section:: *)
(*Argument Parsing*)

(* Usage and help text *)
$usage = "wolframscript -f WolframLanguageContext.wls <context>";

$helpText = StringJoin[
    "Usage: ", $usage, "\n\n",
    "Uses semantic search to retrieve information from various sources that can be used to help write Wolfram Language code. Always use this tool at the start of new conversations or if the topic changes to ensure you have up-to-date relevant information. This uses semantic search, so the context argument should be written in natural language (not a search query) and contain as much detail as possible.\n\n",
    "Arguments:\n",
    "  context (required): A detailed summary of what the user is trying to achieve or learn about.\n"
];

(* Check for --usage flag *)
If[ MemberQ[ $ScriptCommandLine, "--usage" ],
    WriteString[ "stdout", $helpText ];
    Exit[ 0 ]
];

(* Parse command-line arguments *)
Module[ { rawArgs, positional, flags, i, key, value },

    rawArgs = Drop[ $ScriptCommandLine, 1 ];
    positional = {};
    flags = <| |>;
    i = 1;

    While[ i <= Length @ rawArgs,
        If[ StringStartsQ[ rawArgs[[ i ]], "--" ],
            key = StringDrop[ rawArgs[[ i ]], 2 ];
            If[ i + 1 <= Length @ rawArgs,
                value = rawArgs[[ i + 1 ]];
                flags[ key ] = value;
                i += 2,
                (* --flag with no value *)
                WriteString[ "stderr", "[Error] Flag --" <> key <> " requires a value.\n" ];
                Exit[ 1 ]
            ],
            AppendTo[ positional, rawArgs[[ i ]] ];
            i += 1
        ]
    ];

    $parsedArgs = <| |>;
    (* Validate required arguments *)
    If[ Length @ positional < 1,
        WriteString[ "stderr", "[Error] Missing required argument(s).\n\n" <> $helpText ];
        Exit[ 1 ]
    ];

    $parsedArgs[ "context" ] = positional[[ 1 ]];
];

(* ::Section:: *)
(*Tool Invocation*)

Quiet[
    PacletInstall[ "Wolfram/MCPServer" ],
    PacletInstall::samevers
];
Get[ "Wolfram`MCPServer`" ];

tool = $DefaultMCPTools[ "WolframLanguageContext" ];

If[ ! MatchQ[ tool, _LLMTool ],
    WriteString[ "stderr", "[Error] Failed to load tool: WolframLanguageContext\n" ];
    Exit[ 1 ]
];

result = Quiet[
    tool[ $parsedArgs ],
    { General::messages }
];

(* Handle image content: replace with text placeholder *)
result = StringReplace[
    Replace[ result, Except[ _String ] :> ToString[ result, InputForm ] ],
    RegularExpression[ "!\\[([^]]*)\\]\\(data:image[^)]+\\)" ] -> "[Image: $1]"
];

WriteString[ "stdout", result ];

If[ FailureQ @ result, Exit[ 1 ], Exit[ 0 ] ];

(* :!CodeAnalysis::EndBlock:: *)