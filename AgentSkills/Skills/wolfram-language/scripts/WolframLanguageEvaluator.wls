#!/usr/bin/env wolframscript

(* Generated by BuildAgentSkills.wls - do not edit manually *)

(* :!CodeAnalysis::BeginBlock:: *)
(* :!CodeAnalysis::Disable::SuspiciousSessionSymbol:: *)

(* ::Section:: *)
(*Argument Parsing*)

(* Usage and help text *)
$usage = "wolframscript -f WolframLanguageEvaluator.wls <code> [--timeConstraint value]";

$helpText = StringJoin[
    "Usage: ", $usage, "\n\n",
    "Evaluates Wolfram Language code for the user in a Wolfram Language kernel.\nDo not ask permission to evaluate code.\nYou have read access to local files.\nAlways use the Wolfram context tool before using this tool to make sure you have the most up-to-date information.\n\nUse `\\[FreeformPrompt][\"query\"]` to parse natural language into Wolfram Language expressions (like ctrl+= in notebooks). Always use this for `Quantity`, `Entity`, `EntityClass`, etc. It composes freely: `ColorNegate[\\[FreeformPrompt][\"picture of a cat\"]]`.\n\nExamples:\n```\n\\[FreeformPrompt][\"France population\"]  (* Entity property value *)\n\\[FreeformPrompt][\"123 terawatt hours\"] (* Quantity *)\n```\n\nThe argument MUST be a string literal -- it parses before evaluation, so runtime construction will not work.\n\n",
    "Arguments:\n",
    "  code (required): The Wolfram Language code to evaluate.\n",
    "  --timeConstraint: The time constraint for the evaluation. Uses the server's configured default if not specified.\n"
];

(* Check for --usage flag *)
If[ MemberQ[ $ScriptCommandLine, "--usage" ],
    WriteString[ "stdout", $helpText ];
    Exit[ 0 ]
];

(* Parse command-line arguments *)
Module[ { rawArgs, positional, flags, i, key, value },

    rawArgs = Drop[ $ScriptCommandLine, 1 ];
    positional = { };
    flags = <| |>;
    i = 1;

    While[ i <= Length @ rawArgs,
        If[ StringStartsQ[ rawArgs[[ i ]], "--" ],
            key = StringDrop[ rawArgs[[ i ]], 2 ];
            If[ i + 1 <= Length @ rawArgs,
                value = rawArgs[[ i + 1 ]];
                flags[ key ] = value;
                i += 2,
                (* --flag with no value *)
                WriteString[ "stderr", "[Error] Flag --" <> key <> " requires a value.\n" ];
                Exit[ 1 ]
            ],
            AppendTo[ positional, rawArgs[[ i ]] ];
            i += 1
        ]
    ];

    $parsedArgs = <| |>;
    (* Validate required arguments *)
    If[ Length @ positional < 1,
        WriteString[ "stderr", "[Error] Missing required argument(s).\n\n" <> $helpText ];
        Exit[ 1 ]
    ];

    $parsedArgs[ "code" ] = positional[[ 1 ]];
    If[ KeyExistsQ[ flags, "timeConstraint" ], $parsedArgs[ "timeConstraint" ] = flags[ "timeConstraint" ] ];
];

(* ::Section:: *)
(*Tool Invocation*)

Quiet[
    PacletInstall[ "Wolfram/AgentTools" ],
    PacletInstall::samevers
];
Get[ "Wolfram`AgentTools`" ];

tool = $DefaultMCPTools[ "WolframLanguageEvaluator" ];

If[ ! MatchQ[ tool, _LLMTool ],
    WriteString[ "stderr", "[Error] Failed to load tool: WolframLanguageEvaluator\n" ];
    Exit[ 1 ]
];

result = Quiet[
    tool[ $parsedArgs ],
    { General::messages }
];


(* Post-process result *)
postProcessResult[ result_String ] := result;
postProcessResult[ KeyValuePattern[ "String" -> result_String ] ] := result;
postProcessResult[ KeyValuePattern[ "Content" -> result_ ] ] := postProcessResult @ result;
postProcessResult[ content: { KeyValuePattern[ "type" -> _String ]... } ] := StringJoin @ Flatten[ postProcessResult /@ content ];
postProcessResult[ KeyValuePattern @ { "type" -> "text", "text" -> result_String } ] := result;
postProcessResult[ KeyValuePattern[ "type" -> "image" ] ] := "<image>";

postProcessResult[ failure_Failure ] := (
    WriteString[ "stderr", "[Error] " <> ToString @ failure[ "Message" ] ];
    Exit[ 1 ];
);

postProcessResult[ other___ ] := (
    WriteString[ "stderr", "[Error] Unexpected result: " <> ToString @ HoldCompleteForm @ other ];
    Exit[ 1 ];
);

result = postProcessResult @ result;

If[ ! TrueQ @ StringQ @ result,
    WriteString[ "stderr", "[Error] Unexpected result: " <> ToString @ result ];
    Exit[ 1 ];
];

WriteString[ "stdout", result ];
Exit[ 0 ];

(* :!CodeAnalysis::EndBlock:: *)