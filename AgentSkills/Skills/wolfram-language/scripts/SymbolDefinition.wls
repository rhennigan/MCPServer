#!/usr/bin/env wolframscript

(* Generated by BuildAgentSkills.wls - do not edit manually *)

(* :!CodeAnalysis::BeginBlock:: *)
(* :!CodeAnalysis::Disable::SuspiciousSessionSymbol:: *)

(* ::Section:: *)
(*Argument Parsing*)

(* Usage and help text *)
$usage = "wolframscript -script SymbolDefinition.wls <symbols> [--includeContextDetails value] [--maxLength value]";

$helpText = StringJoin[
    "Usage: ", $usage, "\n\n",
    "Retrieves the definitions of one or more Wolfram Language symbols and returns them in a readable markdown format.\nThe tool generates clean, formatted definition strings by intelligently managing the context path to minimize fully qualified symbol names.\n\nUse fully qualified symbol names (e.g., System`Plus, Wolfram`MCPServer`CreateMCPServer) if the context is known.\nMultiple symbols can be requested by separating them with commas.\n\n",
    "Arguments:\n",
    "  symbols (required): The symbol name (or multiple names, comma separated).\n",
    "  --includeContextDetails: Whether to include a JSON map showing which symbols belong to which contexts (default: false).\n",
    "  --maxLength: Maximum character length for output before truncation (default: 10000).\n"
];

(* Check for --help flag *)
If[ MemberQ[ $ScriptCommandLine, "--help" | "-h" ],
    WriteString[ "stdout", $helpText ];
    Exit[ 0 ]
];

(* Parse command-line arguments *)
Module[ { rawArgs, positional, flags, i, key, value },

    rawArgs = Drop[ $ScriptCommandLine, 1 ];
    positional = {};
    flags = <| |>;
    i = 1;

    While[ i <= Length @ rawArgs,
        If[ StringStartsQ[ rawArgs[[ i ]], "--" ],
            key = StringDrop[ rawArgs[[ i ]], 2 ];
            If[ i + 1 <= Length @ rawArgs,
                value = rawArgs[[ i + 1 ]];
                flags[ key ] = value;
                i += 2,
                (* --flag with no value *)
                WriteString[ "stderr", "[Error] Flag --" <> key <> " requires a value.\n" ];
                Exit[ 1 ]
            ],
            AppendTo[ positional, rawArgs[[ i ]] ];
            i += 1
        ]
    ];

    $parsedArgs = <| |>;
    (* Validate required arguments *)
    If[ Length @ positional < 1,
        WriteString[ "stderr", "[Error] Missing required argument(s).\n\n" <> $helpText ];
        Exit[ 1 ]
    ];

    $parsedArgs[ "symbols" ] = positional[[ 1 ]];
    If[ KeyExistsQ[ flags, "includeContextDetails" ], $parsedArgs[ "includeContextDetails" ] = flags[ "includeContextDetails" ] ];
    If[ KeyExistsQ[ flags, "maxLength" ], $parsedArgs[ "maxLength" ] = flags[ "maxLength" ] ];
];

(* ::Section:: *)
(*Tool Invocation*)

Quiet[
    PacletInstall[ "Wolfram/MCPServer" ],
    PacletInstall::samevers
];
Get[ "Wolfram`MCPServer`" ];

tool = $DefaultMCPTools[ "SymbolDefinition" ];

If[ ! MatchQ[ tool, _LLMTool ],
    WriteString[ "stderr", "[Error] Failed to load tool: SymbolDefinition\n" ];
    Exit[ 1 ]
];

result = Quiet[
    tool[ $parsedArgs ],
    { General::messages }
];

(* Handle image content: replace with text placeholder *)
result = StringReplace[
    Replace[ result, Except[ _String ] :> ToString[ result, InputForm ] ],
    RegularExpression[ "!\\[([^]]*)\\]\\(data:image[^)]+\\)" ] -> "[Image: $1]"
];

WriteString[ "stdout", result ];

If[ FailureQ @ result, Exit[ 1 ], Exit[ 0 ] ];

(* :!CodeAnalysis::EndBlock:: *)