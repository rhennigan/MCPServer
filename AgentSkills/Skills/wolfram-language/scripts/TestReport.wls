#!/usr/bin/env wolframscript

(* Generated by BuildAgentSkills.wls — do not edit manually *)

(* ::Section:: *)
(*Argument Parsing*)

(* Usage and help text *)
$usage = "wolframscript -script TestReport.wls <paths> [--timeConstraint value] [--memoryConstraint value] [--newKernel value]";

$helpText = StringJoin[
    "Usage: ", $usage, "\n\n",
    "Runs Wolfram Language test files (.wlt) and returns a report of the results\n\n",
    "Arguments:\n",
    "  paths (required): Comma separated list of paths to Wolfram Language test files (.wlt) or directories of test files\n",
    "  --timeConstraint: An optional time constraint (in seconds) for each test file\n",
    "  --memoryConstraint: An optional memory constraint (in bytes) for each test file\n",
    "  --newKernel: Whether to use a fresh kernel for running tests (default is true)\n"
];

(* Check for --help flag *)
If[ MemberQ[ $ScriptCommandLine, "--help" | "-h" ],
    WriteString[ "stdout", $helpText ];
    Exit[ 0 ]
];

(* Parse command-line arguments *)
Module[ { rawArgs, positional, flags, i, key, value },

    rawArgs = Drop[ $ScriptCommandLine, 1 ];
    positional = {};
    flags = <| |>;
    i = 1;

    While[ i <= Length @ rawArgs,
        If[ StringStartsQ[ rawArgs[[ i ]], "--" ],
            key = StringDrop[ rawArgs[[ i ]], 2 ];
            If[ i + 1 <= Length @ rawArgs,
                value = rawArgs[[ i + 1 ]];
                flags[ key ] = value;
                i += 2,
                (* --flag with no value *)
                WriteString[ "stderr", "[Error] Flag --" <> key <> " requires a value.\n" ];
                Exit[ 1 ]
            ],
            AppendTo[ positional, rawArgs[[ i ]] ];
            i += 1
        ]
    ];

    (* Validate required arguments *)
    If[ Length @ positional < 1,
        WriteString[ "stderr", "[Error] Missing required argument(s).\n\n" <> $helpText ];
        Exit[ 1 ]
    ];

    $parsedArgs = <| |>;
    $parsedArgs[ "paths" ] = positional[[ 1 ]];
    If[ KeyExistsQ[ flags, "timeConstraint" ], $parsedArgs[ "timeConstraint" ] = flags[ "timeConstraint" ] ];
    If[ KeyExistsQ[ flags, "memoryConstraint" ], $parsedArgs[ "memoryConstraint" ] = flags[ "memoryConstraint" ] ];
    If[ KeyExistsQ[ flags, "newKernel" ], $parsedArgs[ "newKernel" ] = flags[ "newKernel" ] ];
];

(* ::Section:: *)
(*Tool Invocation*)

Quiet[
    PacletInstall[ "Wolfram/MCPServer" ],
    PacletInstall::samevers
];
Get[ "Wolfram`MCPServer`" ];

tool = $DefaultMCPTools[ "TestReport" ];

If[ ! MatchQ[ tool, _LLMTool ],
    WriteString[ "stderr", "[Error] Failed to load tool: TestReport\n" ];
    Exit[ 1 ]
];

result = Quiet[
    tool[ $parsedArgs ],
    { General::messages }
];

(* Handle image content: replace with text placeholder *)
result = StringReplace[
    Replace[ result, Except[ _String ] :> ToString[ result, InputForm ] ],
    RegularExpression[ "!\\[([^]]*)\\]\\(data:image[^)]+\\)" ] -> "[Image: $1]"
];

WriteString[ "stdout", result ];

If[ FailureQ @ result, Exit[ 1 ], Exit[ 0 ] ];
